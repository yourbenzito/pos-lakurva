{
  "name": "sistema-ventas",
  "version": "1.0.0",
  "description": "Sistema de ventas offline",
  "author": "Sistema Ventas",
  "main": "main.js",
  "scripts": {
    "start": "node backend/server.js",
    "app": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.benzo.sistemaventas",
    "productName": "Sistema de Ventas",
    "icon": "icons/icon.png",
    "asarUnpack": [
      "node_modules/sqlite3/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon.png",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "pdfkit": "^0.17.2",
    "pdfmake": "^0.3.5",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0"
  }
}