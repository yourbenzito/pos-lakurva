{
  "name": "sistema-ventas",
  "version": "1.0.0",
  "description": "Sistema de ventas offline",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.benzo.sistemaventas",
    "productName": "Sistema de Ventas",
    "asarUnpack": [
      "node_modules/sqlite3/**"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0"
  }
}
